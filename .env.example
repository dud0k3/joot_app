# Telegram
BOT_TOKEN=replace_me
ADMIN_IDS=861098409
APP_URL=https://your-dockhost-domain.example
BOT_MODE=polling
DEV_MODE=false
PUBLIC_ERROR_DETAILS=false
SUPPORT_USERNAME=
BUILD_VERSION=joot-clean-production-2026-06-29-v7-joot8-ui-clean

# Database. For Dockhost network disk: mount disk to /data.
DATABASE_URL=sqlite:////data/joot.db

# VPN provider
VPN_PROVIDER=stealthsurf

# StealthSurf API
STEALTHSURF_API_BASE=https://api.stealthsurf.net
STEALTHSURF_API_TOKEN=stlth_XXXXXXXX_YYYYYYYYYYYYYYYYYYYYYYYY
STEALTHSURF_CLOUD_SERVER_ID=1343
STEALTHSURF_DEVICE_LIMIT=3

# JOOT bundle: 1 Auto config + 7 regular configs.
STEALTHSURF_USE_JOOT_BUNDLE=true
STEALTHSURF_EXPECTED_CONFIG_COUNT=8
STEALTHSURF_CONFIG_TITLE_PREFIX=JOOT
STEALTHSURF_PROTOCOLS=vless,trojan,hysteria2,shadowsocks-2022

# Safe StealthSurf subscription mode
STEALTHSURF_USE_CUSTOM_SUBSCRIPTIONS=true
STEALTHSURF_SUBSCRIPTION_PUBLIC_BASE=https://connect.stealthsurf.net/to
STEALTHSURF_ALLOW_ENCRYPTED_LINK_FALLBACK=false

# Xray settings
STEALTHSURF_USE_EXTENDED_SETTINGS=true
STEALTHSURF_BLOCK_BITTORRENT=true
STEALTHSURF_USE_GRPC=true
STEALTHSURF_GRPC_MULTI_MODE=true
STEALTHSURF_USE_XHTTP=false
STEALTHSURF_USE_WARP=false
STEALTHSURF_RANDOMIZE_FINGERPRINT=true
STEALTHSURF_PASS_ALL_TRAFFIC_THROUGH_VPN=false
STEALTHSURF_ENABLE_FAMILY_FILTER=false
STEALTHSURF_DISABLE_REALITY=false
STEALTHSURF_DISABLE_FLOW_REALITY=false
STEALTHSURF_VERIFY_SSL=true
STEALTHSURF_REQUEST_RETRIES=4
STEALTHSURF_AVAILABLE_ITEMS_RETRIES=12

# JOOT subscription limits in local DB
DEFAULT_SUBSCRIPTION_DAYS=30
DEFAULT_SUBSCRIPTION_TRAFFIC_GB=0
DEFAULT_SUBSCRIPTION_DEVICES=3

PAYMENT_PROVIDER=none
